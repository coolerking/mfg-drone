# 動作モード: mock（実機なし・推奨初期値） / real（実機）
TELLO_MODE=mock

# ステーションモードで自宅 LAN に接続した Tello EDU の IP
# （ルーターの DHCP により動的割り当て）。real モード時に使用。
TELLO_IP=192.168.11.31

# サーバ
HOST=0.0.0.0
PORT=8000

# 安全パラメータ（docs/safety.md 参照）
# WebSocket heartbeat 途絶からホバリングまでの猶予（秒）
WATCHDOG_TIMEOUT_SEC=2.0
# 追従ループの最大コマンドレート（Hz）
MAX_COMMAND_RATE_HZ=10
# rc 各軸の出力上限（絶対値, 0-100）
MAX_RC_SPEED=40
# 離陸を許可する最低電池残量（%）
MIN_BATTERY_TO_TAKEOFF=20

# モックモードで Webカメラ映像を使う場合のデバイス番号（未使用ならダミー映像）
MOCK_CAMERA_INDEX=0

# ログレベル
LOG_LEVEL=INFO
