# ============================================================
# mfg-drone 環境変数設定例
# cp .env.example .env して編集してから使用する
# ============================================================

# 動作モード: mock（実機なし・推奨初期値） / real（実機）
TELLO_MODE=mock

# ステーションモードで自宅 LAN に接続した Tello EDU の IP
# （ルーターの DHCP により動的割り当て）。real モード時に使用。
TELLO_IP=192.168.11.31

# サーバ
HOST=0.0.0.0
PORT=8000

# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# モックモードで Webカメラ映像を使う場合のデバイス番号
# 指定なし or -1 の場合はダミー生成フレームを使用
MOCK_CAMERA_INDEX=-1

# ==============================================================
# ⚠️  以下の安全パラメータは M2/M3 着手前に機体オーナーが確認・調整する
# docs/safety.md S-2〜S-6 参照
# ==============================================================

# 手動 1 ステップの移動距離 (cm)  SDK 許容: 20–500
MOVE_DISTANCE_CM=30

# 手動 1 ステップの旋回角度 (度)  SDK 許容: 1–360
ROTATE_DEGREES=20

# 追従ループの最大 rc 送信レート (Hz)  S-2
MAX_COMMAND_RATE_HZ=10

# rc 各軸の出力上限 (絶対値, 0–100)  S-3
MAX_RC_SPEED=30

# WebSocket heartbeat 途絶 → ホバリングまでの猶予 (秒)  S-4
WATCHDOG_TIMEOUT_SEC=2.0

# ホバリング後 → 自動着陸までの猶予 (秒)  S-4
AUTOLAND_TIMEOUT_SEC=5.0

# 電池残量 警告表示閾値 (%)  S-6
BATTERY_WARN_PCT=30

# 電池残量 離陸禁止・着陸推奨閾値 (%)  S-6
MIN_BATTERY_TO_TAKEOFF=15
